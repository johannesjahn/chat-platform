{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "types": ["bun"],

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },

  // The `web/` frontend is a separate project with its own tsconfig.
  // scripts/loadtest is excluded: those are k6 scripts, not Bun/Node code —
  // they import module specifiers like "k6/http" that only resolve inside
  // k6's own runtime, so tsc has nothing to check them against.
  "include": ["src", "scripts"],
  "exclude": ["node_modules", "web", "scripts/loadtest"]
}
