{
  "name": "chat-platform-web",
  "version": "0.12.4",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3001",
    "build": "vite build && vite build --config vite.pwa.config.ts",
    "preview": "vite preview --port 3001",
    "gen:routes": "tsr generate",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "gen:types": "bun run ../scripts/gen-openapi.ts && openapi-typescript ../openapi.json -o src/lib/api-types.ts"
  },
  "dependencies": {
    "@radix-ui/react-slot": "1.3.0",
    "@tanstack/query-sync-storage-persister": "5.101.2",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-query-persist-client": "5.101.2",
    "@tanstack/react-router": "1.170.18",
    "@tanstack/react-start": "1.168.30",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "gsap": "3.15.0",
    "lucide-react": "1.25.0",
    "openapi-fetch": "0.17.0",
    "openapi-react-query": "0.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "4.3.3",
    "@tanstack/router-cli": "1.167.21",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "openapi-typescript": "7.13.0",
    "tailwindcss": "4.3.3",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vite": "8.1.5",
    "vite-plugin-pwa": "1.3.0",
    "vite-tsconfig-paths": "6.1.1"
  }
}
