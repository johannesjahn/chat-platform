# PGlite data directory (an embedded Postgres) — omit for an in-memory,
# non-persistent database.
DB_PATH=./pgdata
PORT=3000
# Secret used to sign refresh JWTs (HS256). Use a long random value in production.
JWT_SECRET=change-me-to-a-long-random-secret
# Origin allowed to call this API from the browser (the web frontend).
WEB_ORIGIN=http://localhost:3001
