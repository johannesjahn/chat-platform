# PGlite data directory (an embedded Postgres) — omit for an in-memory,
# non-persistent database. Ignored if DATABASE_URL is set.
DB_PATH=./pgdata
# Connect to a real Postgres instead of embedded PGlite (e.g. `docker compose
# up` sets this to point at its `db` service). Leave unset to use DB_PATH
# above.
# DATABASE_URL=postgres://chat_platform:chat_platform@localhost:5432/chat_platform
# Realtime (chat/post) events are fanned out over Redis Pub/Sub so multiple
# app instances behind a load balancer share them — see src/PubSub.ts. Unset
# (the default) falls back to an in-memory single-process implementation,
# which is correct as long as you're only running one instance. `docker
# compose up` sets this to point at its `redis` service.
# REDIS_URL=redis://localhost:6379
PORT=3000
# Secret used to sign refresh JWTs (HS256). Required — use a long random
# value; anyone who knows it can forge an admin access token. `docker compose
# up` refuses to start without one set (no insecure fallback default).
JWT_SECRET=change-me-to-a-long-random-secret
# Origin allowed to call this API from the browser (the web frontend).
WEB_ORIGIN=http://localhost:3001

# Only read by docker-compose.yml (not by the app directly) — required when
# running `docker compose up`, to avoid shipping a well-known default
# Postgres/Redis password.
POSTGRES_PASSWORD=change-me-to-a-long-random-secret
REDIS_PASSWORD=change-me-to-a-long-random-secret
